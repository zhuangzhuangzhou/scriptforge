# AI ScriptFlow - Test Environment Configuration
APP_NAME="AI ScriptFlow (Test)"
DEBUG=True

# 安全密钥
SECRET_KEY="test-secret-key-6d8f2b1e"
JWT_SECRET_KEY="test-jwt-key-9a2c4e6b"

# 数据库配置 (连接到宿主机的 35432 端口)
# 注意：在 Docker 容器内部，使用 REMOVED_IP 访问宿主机服务
DATABASE_URL=postgresql+asyncpg://postgres:postgres@REMOVED_IP:35432/novel_script

# Redis 配置
REDIS_URL=redis://REMOVED_IP:6379/0
CELERY_BROKER_URL=redis://REMOVED_IP:6379/0
CELERY_RESULT_BACKEND=redis://REMOVED_IP:6379/0

# MinIO 配置
MINIO_ENDPOINT=REMOVED_IP:19000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=REMOVED_SECRET
MINIO_SECURE=False
MINIO_BUCKET_NAME=novel-scripts

# 跨域配置 (允许本地前端测试)
CORS_ORIGINS=["http://localhost:5173", "http://REMOVED_IP"]
