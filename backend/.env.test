# ScriptForge - Test Environment Configuration
APP_NAME="ScriptForge (Test)"
DEBUG=True

# 安全密钥
SECRET_KEY="test-secret-key-CHANGE-IN-PRODUCTION"
JWT_SECRET_KEY="test-jwt-secret-key-CHANGE-IN-PRODUCTION"

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/scriptforge

# Redis 配置
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET_NAME=scriptforge

# 跨域配置
CORS_ORIGINS=["http://localhost:5173"]