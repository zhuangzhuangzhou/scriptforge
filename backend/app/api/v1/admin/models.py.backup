"""AI 模型管理 API"""
from typing import List
from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy import select, func
from sqlalchemy.ext.asyncio import AsyncSession

from app.core.database import get_db
from app.models.ai_model import AIModel
from app.models.ai_model_provider import AIModelProvider
from app.models.ai_model_pricing import AIModelPricing
from app.schemas.ai_model import (
    AIModelCreate,
    AIModelUpdate,
    AIModelResponse
)
from app.api.v1.admin import check_admin

router = APIRouter()


@router.get("", response_model=List[AIModelResponse])
async def get_models(
    provider_id: str = None,
    db: AsyncSession = Depends(get_db),
    _: None = Depends(check_admin)
):
    """获取模型列表

    Args:
        provider_id: 可选，按提供商筛选
    """
    # 构建查询
    query = select(AIModel, AIModelProvider).join(
        AIModelProvider,
        AIModel.provider_id == AIModelProvider.id
    ).order_by(AIModel.created_at.desc())

    # 如果指定了提供商，添加筛选条件
    if provider_id:
        query = query.where(AIModel.provider_id == provider_id)

    result = await db.execute(query)

    models = []
    for model, provider in result:
        model_dict = {
            "id": str(model.id),
            "provider_id": str(model.provider_id),
            "provider_name": provider.display_name,
            "model_key": model.model_key,
            "display_name": model.display_name,
            "model_type": model.model_type,
            "max_tokens": model.max_tokens,
            "max_input_tokens": model.max_input_tokens,
            "max_output_tokens": model.max_output_tokens,
            "timeout_seconds": model.timeout_seconds,
            "temperature_default": model.temperature_default,
            "supports_streaming": model.supports_streaming,
            "supports_function_calling": model.supports_function_calling,
            "description": model.description,
            "is_enabled": model.is_enabled,
            "is_default": model.is_default,
            "created_at": model.created_at,
            "updated_at": model.updated_at
        }
        models.append(model_dict)

    return models


@router.get("/{model_id}", response_model=AIModelResponse)
async def get_model(
    model_id: str,
    db: AsyncSession = Depends(get_db),
    _: None = Depends(check_admin)
):
    """获取模型详情"""
    # 查询模型及其提供商
    result = await db.execute(
        select(AIModel, AIModelProvider)
        .join(AIModelProvider, AIModel.provider_id == AIModelProvider.id)
        .where(AIModel.id == model_id)
    )
    row = result.first()

    if not row:
        raise HTTPException(status_code=404, detail="模型不存在")

    model, provider = row

    return {
        "id": str(model.id),
        "provider_id": str(model.provider_id),
        "provider_name": provider.display_name,
        "model_key": model.model_key,
        "display_name": model.display_name,
        "model_type": model.model_type,
        "max_tokens": model.max_tokens,
        "max_input_tokens": model.max_input_tokens,
        "max_output_tokens": model.max_output_tokens,
        "timeout_seconds": model.timeout_seconds,
        "temperature_default": model.temperature_default,
        "supports_streaming": model.supports_streaming,
        "supports_function_calling": model.supports_function_calling,
        "description": model.description,
        "is_enabled": model.is_enabled,
        "is_default": model.is_default,
        "created_at": model.created_at,
        "updated_at": model.updated_at
    }


@router.delete("/{model_id}")
async def delete_model(
    model_id: str,
    db: AsyncSession = Depends(get_db),
    _: None = Depends(check_admin)
):
    """删除模型"""
    # 查询模型
    result = await db.execute(
        select(AIModel).where(AIModel.id == model_id)
    )
    model = result.scalar_one_or_none()

    if not model:
        raise HTTPException(status_code=404, detail="模型不存在")

    # 如果是默认模型，不允许删除
    if model.is_default:
        raise HTTPException(status_code=400, detail="无法删除默认模型，请先设置其他模型为默认")

    # 删除模型
    await db.delete(model)
    await db.commit()

    return {"message": "模型已删除"}


@router.post("/{model_id}/toggle", response_model=AIModelResponse)
async def toggle_model(
    model_id: str,
    db: AsyncSession = Depends(get_db),
    _: None = Depends(check_admin)
):
    """启用/禁用模型"""
    # 查询模型及其提供商
    result = await db.execute(
        select(AIModel, AIModelProvider)
        .join(AIModelProvider, AIModel.provider_id == AIModelProvider.id)
        .where(AIModel.id == model_id)
    )
    row = result.first()

    if not row:
        raise HTTPException(status_code=404, detail="模型不存在")

    model, provider = row

    # 如果是默认模型且要禁用，不允许
    if model.is_default and model.is_enabled:
        raise HTTPException(status_code=400, detail="无法禁用默认模型，请先设置其他模型为默认")

    # 切换状态
    model.is_enabled = not model.is_enabled
    await db.commit()
    await db.refresh(model)

    return {
        "id": str(model.id),
        "provider_id": str(model.provider_id),
        "provider_name": provider.display_name,
        "model_key": model.model_key,
        "display_name": model.display_name,
        "model_type": model.model_type,
        "max_tokens": model.max_tokens,
        "max_input_tokens": model.max_input_tokens,
        "max_output_tokens": model.max_output_tokens,
        "timeout_seconds": model.timeout_seconds,
        "temperature_default": model.temperature_default,
        "supports_streaming": model.supports_streaming,
        "supports_function_calling": model.supports_function_calling,
        "description": model.description,
        "is_enabled": model.is_enabled,
        "is_default": model.is_default,
        "created_at": model.created_at,
        "updated_at": model.updated_at
    }


@router.post("/{model_id}/set-default", response_model=AIModelResponse)
async def set_default_model(
    model_id: str,
    db: AsyncSession = Depends(get_db),
    _: None = Depends(check_admin)
):
    """设置为默认模型"""
    # 查询模型及其提供商
    result = await db.execute(
        select(AIModel, AIModelProvider)
        .join(AIModelProvider, AIModel.provider_id == AIModelProvider.id)
        .where(AIModel.id == model_id)
    )
    row = result.first()

    if not row:
        raise HTTPException(status_code=404, detail="模型不存在")

    model, provider = row

    # 如果模型未启用，不允许设置为默认
    if not model.is_enabled:
        raise HTTPException(status_code=400, detail="无法将未启用的模型设置为默认")

    # 取消其他模型的默认状态
    await db.execute(
        AIModel.__table__.update().values(is_default=False)
    )

    # 设置当前模型为默认
    model.is_default = True
    await db.commit()
    await db.refresh(model)

    return {
        "id": str(model.id),
        "provider_id": str(model.provider_id),
        "provider_name": provider.display_name,
        "model_key": model.model_key,
        "display_name": model.display_name,
        "model_type": model.model_type,
        "max_tokens": model.max_tokens,
        "max_input_tokens": model.max_input_tokens,
        "max_output_tokens": model.max_output_tokens,
        "timeout_seconds": model.timeout_seconds,
        "temperature_default": model.temperature_default,
        "supports_streaming": model.supports_streaming,
        "supports_function_calling": model.supports_function_calling,
        "description": model.description,
        "is_enabled": model.is_enabled,
        "is_default": model.is_default,
        "created_at": model.created_at,
        "updated_at": model.updated_at
    }


@router.post("", response_model=AIModelResponse)
async def create_model(
    model_data: AIModelCreate,
    db: AsyncSession = Depends(get_db),
    _: None = Depends(check_admin)
):
    """创建模型"""
    # 检查提供商是否存在
    result = await db.execute(
        select(AIModelProvider).where(AIModelProvider.id == model_data.provider_id)
    )
    provider = result.scalar_one_or_none()
    if not provider:
        raise HTTPException(status_code=404, detail="提供商不存在")

    # 检查模型标识是否已存在（同一提供商下）
    result = await db.execute(
        select(AIModel).where(
            AIModel.provider_id == model_data.provider_id,
            AIModel.model_key == model_data.model_key
        )
    )
    existing = result.scalar_one_or_none()
    if existing:
        raise HTTPException(status_code=400, detail="该提供商下已存在相同的模型标识")

    # 创建模型
    model = AIModel(
        provider_id=model_data.provider_id,
        model_key=model_data.model_key,
        display_name=model_data.display_name,
        model_type=model_data.model_type,
        max_tokens=model_data.max_tokens,
        max_input_tokens=model_data.max_input_tokens,
        max_output_tokens=model_data.max_output_tokens,
        timeout_seconds=model_data.timeout_seconds,
        temperature_default=model_data.temperature_default,
        supports_streaming=model_data.supports_streaming,
        supports_function_calling=model_data.supports_function_calling,
        description=model_data.description
    )
    db.add(model)
    await db.commit()
    await db.refresh(model)

    return {
        "id": str(model.id),
        "provider_id": str(model.provider_id),
        "provider_name": provider.display_name,
        "model_key": model.model_key,
        "display_name": model.display_name,
        "model_type": model.model_type,
        "max_tokens": model.max_tokens,
        "max_input_tokens": model.max_input_tokens,
        "max_output_tokens": model.max_output_tokens,
        "timeout_seconds": model.timeout_seconds,
        "temperature_default": model.temperature_default,
        "supports_streaming": model.supports_streaming,
        "supports_function_calling": model.supports_function_calling,
        "description": model.description,
        "is_enabled": model.is_enabled,
        "is_default": model.is_default,
        "created_at": model.created_at,
        "updated_at": model.updated_at
    }


