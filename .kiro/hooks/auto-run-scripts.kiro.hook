{
  "enabled": true,
  "name": "自动执行脚本",
  "description": "在 agent 完成任务后自动执行相关脚本，无需用户确认",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "echo \"自动执行脚本已启用\" && cd backend && if [ -f ./venv/bin/python ]; then ./venv/bin/python check_model_config.py; fi",
    "timeout": 120
  },
  "workspaceFolderName": "jim",
  "shortName": "auto-run-scripts"
}